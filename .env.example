# Core model access
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com
GROQ_API_KEY=gsk-your-key-here
LLM_AGENT_MAX_TOKENS=2048
LLM_SKILL_MAX_TOKENS=2048

# Compiler behavior
PROMPT_COMPILER_MODE=conservative

# Optional internal auth hardening (public app routes do not require end-user Prompt Compiler API keys)
ADMIN_API_KEY=
PROMPTC_REQUIRE_API_KEY_FOR_ALL=false

# Optional storage controls
DB_DIR=.
PROMPTC_UPLOAD_DIR=.promptc_uploads
PROMPTC_RAG_DB_PATH=
PROMPTC_RAG_ALLOWED_ROOTS=

# Optional frontend override
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
