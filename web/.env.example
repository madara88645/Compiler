# Copy to .env.local and fill in values.
# Next.js will auto-load .env.local; do not commit it.

# URL of the FastAPI backend reachable from the browser.
# Local dev default:
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# The API key the web server uses to authenticate with the backend
# for protected proxy routes.
PROMPTC_SERVER_API_KEY=
